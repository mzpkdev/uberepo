{
  "name": "uberepo",
  "version": "1.0.0",
  "description": "One workspace for all your repos — a worktree per task across every repo",
  "main": "src/cli.ts",
  "bin": {
    "uberepo": "bin/uberepo.mjs"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "test": "vitest --no-watch",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format .",
    "format:fix": "biome format --fix .",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "dependencies": {
    "cmdore": "file:lib"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
